

fn main(): int {
    # ═══════════════════════════════════════════════
    # 1. Array literal with type inference
    # ═══════════════════════════════════════════════
    mut arr = [10, 20, 30]
    @println("=== 1. Array Literal ===\n")
    @println("arr[0]=%d arr[1]=%d arr[2]=%d\n", arr[0], arr[1], arr[2])

    # ═══════════════════════════════════════════════
    # 2. Array .len / .cap properties
    # ═══════════════════════════════════════════════
    @println("\n=== 2. Properties ===\n")
    @println("arr.len=%lld arr.cap=%lld\n", arr.len, arr.cap)

    # ═══════════════════════════════════════════════
    # 3. Array index assignment (mutation)
    # ═══════════════════════════════════════════════
    @println("\n=== 3. Index Assignment ===\n")
    arr[1] = 99
    @println("arr[1] after mutation = %d\n", arr[1])

    # ═══════════════════════════════════════════════
    # 4. If with array element
    # ═══════════════════════════════════════════════
    @println("\n=== 4. If on Array Element ===\n")
    if arr[1] == 99 {
        @println("arr[1] is 99 - OK\n")
    }
    if arr[0] == 10 {
        @println("arr[0] is 10 - OK\n")
    }

    # ═══════════════════════════════════════════════
    # 5. For-in loop over array
    # ═══════════════════════════════════════════════
    @println("\n=== 5. For-in Loop ===\n")
    for v in arr {
        @println("  elem: %d\n", v)
    }

    # ═══════════════════════════════════════════════
    # 6. Match on array element
    # ═══════════════════════════════════════════════
    @println("\n=== 6. Match ===\n")
    match arr[2] {
        30 => @println("matched 30 OK\n"),
        _ => @println("FAIL\n")
    }
    match arr[0] {
        10 => @println("matched 10 OK\n"),
        20 => @println("FAIL\n"),
        _ => @println("FAIL\n")
    }

    # ═══════════════════════════════════════════════
    # 7. Repeat-array with compile-time count
    # ═══════════════════════════════════════════════
    @println("\n=== 7. Repeat Array ===\n")
    mut zeros = [0; 5]
    @println("zeros.len=%lld zeros[3]=%d\n", zeros.len, zeros[3])

    mut fives = [5; 3]
    @println("fives.len=%lld fives[0]=%d fives[2]=%d\n", fives.len, fives[0], fives[2])

    # ═══════════════════════════════════════════════
    # 8. Tuple creation & destructuring
    # ═══════════════════════════════════════════════
    @println("\n=== 8. Tuple Destructuring ===\n")
    mut a, b, c = (42, 100, 7)
    @println("a=%d b=%d c=%d\n", a, b, c)

    # ═══════════════════════════════════════════════
    # 9. Tuple with mixed types
    # ═══════════════════════════════════════════════
    @println("\n=== 9. Mixed Tuple ===\n")
    mut tup = (1, 2, 3)
    @println("tup.0=%d tup.1=%d tup.2=%d\n", tup)

    # ═══════════════════════════════════════════════
    # 10. Slicing
    # ═══════════════════════════════════════════════
    @println("\n=== 10. Slicing ===\n")
    mut sl = arr[0..2]
    @println("slice.len=%lld\n", sl.len)
    @println("slice[0]=%d slice[1]=%d\n", sl[0], sl[1])

    # ═══════════════════════════════════════════════
    # 11. Nested array in for loop with if
    # ═══════════════════════════════════════════════
    @println("\n=== 11. For + If Integration ===\n")
    mut nums = [1, 2, 3, 4, 5]
    for n in nums {
        if n == 3 {
            @println("  found 3!\n")
        }
    }

    # ═══════════════════════════════════════════════
    # 12. Array of same values with mutation
    # ═══════════════════════════════════════════════
    @println("\n=== 12. Mutate Repeat Array ===\n")
    mut buf = [0; 4]
    buf[0] = 10
    buf[1] = 20
    buf[2] = 30
    buf[3] = 40
    for val in buf {
        @println("  buf: %d\n", val)
    }

    @println("\nAll tests passed!\n")
    return 0
}
